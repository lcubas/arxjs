{
  "name": "@arx/core",
  "version": "0.0.1",
  "description": "Modern authorization library for Node.js and TypeScript",
  "keywords": [
    "authorization",
    "rbac",
    "permissions",
    "roles",
    "access-control",
    "typescript",
    "nodejs"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/arx.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/your-org/arx/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/your-org/arx/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown src/index.ts --format esm,cjs --dts --sourcemap --no-splitting --clean",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsdown": "^0.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.0"
  }
}
