{
  "name": "@arx/core",
  "version": "0.0.1",
  "description": "Modern authorization library for Node.js and TypeScript",
  "keywords": [
    "authorization",
    "rbac",
    "permissions",
    "roles",
    "access-control",
    "typescript",
    "nodejs"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/arx.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/your-org/arx/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/your-org/arx/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md"],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap --treeshake --no-splitting --clean",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  }
}
