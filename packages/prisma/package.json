{
  "name": "@arx/prisma",
  "version": "0.0.1",
  "description": "Prisma adapter for @arx/core — supports all databases Prisma supports",
  "keywords": ["authorization", "rbac", "prisma", "adapter", "typescript"],
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "schema.prisma", "README.md"],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap --treeshake --no-splitting --clean --external @prisma/client --external @arx/core",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@prisma/client": ">=5.0.0",
    "@arx/core": "*"
  },
  "devDependencies": {
    "@prisma/client": "^5.0.0",
    "@arx/core": "*",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  }
}
