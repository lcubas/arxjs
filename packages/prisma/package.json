{
  "name": "@arx/prisma",
  "version": "0.0.1",
  "description": "Prisma adapter for @arx/core — supports all databases Prisma supports",
  "keywords": ["authorization", "rbac", "prisma", "adapter", "typescript"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/arx.git",
    "directory": "packages/prisma"
  },
  "homepage": "https://github.com/your-org/arx/tree/main/packages/prisma#readme",
  "bugs": {
    "url": "https://github.com/your-org/arx/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "schema.prisma", "README.md"],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown src/index.ts --format esm,cjs --dts --sourcemap --no-splitting --clean --external @prisma/client --external @arx/core",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@prisma/client": ">=5.0.0",
    "@arx/core": "*"
  },
  "devDependencies": {
    "@prisma/client": "^5.0.0",
    "@arx/core": "workspace:*",
    "tsdown": "^0.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.0"
  }
}
