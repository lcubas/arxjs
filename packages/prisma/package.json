{
  "name": "@arxjs/prisma",
  "version": "0.0.1",
  "description": "Prisma adapter for @arxjs/core — supports all databases Prisma supports",
  "keywords": [
    "authorization",
    "rbac",
    "prisma",
    "adapter",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lcubas/arxjs.git",
    "directory": "packages/prisma"
  },
  "homepage": "https://github.com/lcubas/arxjs/tree/main/packages/prisma#readme",
  "bugs": {
    "url": "https://github.com/lcubas/arxjs/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "files": [
    "dist",
    "schema.prisma",
    "README.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown src/index.ts --format esm,cjs --dts --sourcemap --no-splitting --clean --external @prisma/client --external @arxjs/core",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@prisma/client": "^5.0.0 || ^6.0.0",
    "@arxjs/core": "*"
  },
  "devDependencies": {
    "@prisma/client": "^6.0.0",
    "@arxjs/core": "workspace:*",
    "tsdown": "^0.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.0"
  }
}
